# GitHub issue creation (PAT for now; GitHub App planned)
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=your-repo-name
GITHUB_TOKEN=ghp_your_token_here
GITHUB_BASE_URL=https://api.github.com

# App origin used to build the QStash worker callback URL
APP_ORIGIN=https://www.mermditor.dev

# Upstash QStash (feedback job queue)
QSTASH_TOKEN=qstash_token_placeholder
QSTASH_URL=https://qstash.upstash.io
QSTASH_CURRENT_SIGNING_KEY=sig_current_placeholder
QSTASH_NEXT_SIGNING_KEY=sig_next_placeholder

# Resend (private feedback notification email)
RESEND_API_KEY=re_resend_key_placeholder
FEEDBACK_EMAIL_TO=you@example.com
FEEDBACK_EMAIL_FROM=feedback@mermditor.dev
